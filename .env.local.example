# Copy this file to .env.local and fill in. The app runs fully WITHOUT any of
# these (seeded demo data + a shared access code), so it works before you wire
# anything up. Set them as you make each part real.

# --- Public site URL (used for SEO sitemap, robots, and social links) ---
NEXT_PUBLIC_SITE_URL=https://learningaccessinitiative.org

# --- Staff access gate (protects /dashboard and all data pages) ---
# Change these before deploying. Anyone with the access code can see student data.
LA_ACCESS_CODE=lai-2026
LA_SESSION_SECRET=change-this-to-a-long-random-string

# --- Form submissions -> email (tutor request / volunteer / contact) ---
# Create a free key at resend.com, verify a sender, then set these. Until set,
# submissions are logged to the server console and the user still sees success.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=you@youremail.com
LEAD_FROM_EMAIL=Learning Access <onboarding@resend.dev>

# --- Supabase (real database + tutor logins) — optional, see README ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Never expose the service role key in NEXT_PUBLIC_* — server-only.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
